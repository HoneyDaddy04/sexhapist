# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.

# ===== Vercel deployment (the /api/* functions) =====
# These use OpenAI directly.

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional model overrides. Defaults shown.
# CHAT_MODEL=gpt-4o-mini
# TRANSCRIBE_MODEL=whisper-1

# Session-cookie HMAC secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_64_random_hex_chars

# ===== Optional: OpenRouter (for the GitHub Pages / alternate deployment) =====
# https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o
# OPENROUTER_TRANSCRIBE_MODEL=openai/gpt-4o-mini-transcribe
# OPENROUTER_REFERER=https://sexhapist.com

# ===== ElevenLabs voice (text-to-speech for bot replies). Optional. =====
# https://elevenlabs.io/app/api-key
ELEVENLABS_API_KEY=

# Optional: ElevenLabs voice IDs (defaults are baked into api/voice.js).
VOICE_ID_HIM=
VOICE_ID_HER=
